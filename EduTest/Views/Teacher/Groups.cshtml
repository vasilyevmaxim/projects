@model IEnumerable<StudentTestingSystem.Models.Entities.Group>
@{
    ViewData["Title"] = "Учебные группы";
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Учебные группы</h2>
    <a asp-action="CreateGroup" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Добавить группу
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@foreach (var g in Model)
{
    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <strong>@g.Name</strong>
                <span class="text-muted ms-2">
                    (@(g.Students?.Count ?? 0) студент(ов))
                </span>
            </div>
            <div>
                <a asp-action="EditGroup" asp-route-id="@g.Id"
                   class="btn btn-sm btn-outline-secondary me-1">
                    Изменить
                </a>
                <form asp-action="DeleteGroup"
                      asp-route-id="@g.Id"
                      method="post"
                      class="d-inline"
                      onsubmit="return confirm('Удалить группу и всех её студентов?');">
                    <button type="submit" class="btn btn-sm btn-outline-danger">
                        Удалить
                    </button>
                </form>
            </div>
        </div>
        <div class="card-body">
            @if (g.Students != null && g.Students.Any())
            {
                <ul class="list-unstyled mb-0">
                    @foreach (var s in g.Students.OrderBy(s => s.FullName))
                    {
                        <li>
                            @s.FullName
                            <span class="text-muted">(@s.Email)</span>
                        </li>
                    }
                </ul>
            }
            else
            {
                <span class="text-muted">Студентов нет</span>
            }
        </div>
    </div>
}