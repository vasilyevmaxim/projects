@model List<Test>
@{
    ViewData["Title"] = $"Тесты курса: {ViewBag.CourseName}";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-2">
                <li class="breadcrumb-item"><a asp-action="Index">Курсы</a></li>
                <li class="breadcrumb-item active">@ViewBag.CourseName</li>
            </ol>
        </nav>
        <h2 class="mb-0">
            <i class="bi bi-clipboard-check me-2 text-primary"></i>@ViewBag.CourseName
        </h2>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="CreateTest" asp-route-courseId="@ViewBag.CourseId" class="btn btn-success btn-lg">
            <i class="bi bi-plus-lg me-2"></i>Создать тест
        </a>
        <a asp-action="CreateLecture" asp-route-courseId="@ViewBag.CourseId"
           class="btn btn-success btn-lg">
            <i class="bi bi-book-half me-1"></i>Создать лекцию
        </a>
        <a asp-action="Index" class="btn btn-outline-primary">
            <i class="bi bi-arrow-left me-2"></i>К курсам
        </a>

    </div>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bi bi-clipboard display-1 text-muted mb-3"></i>
            <h4>Тесты ещё не созданы</h4>
            <p class="text-muted mb-4">Создайте первый тест для этого курса</p>
            <a asp-action="CreateTest" asp-route-courseId="@ViewBag.CourseId" class="btn btn-success btn-lg">
                <i class="bi bi-plus-lg me-2"></i>Создать тест
            </a>
        </div>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var test in Model)
        {
            var now = DateTime.Now;
            var isActive = (!test.AvailableFrom.HasValue || test.AvailableFrom <= now) &&
                           (!test.AvailableUntil.HasValue || test.AvailableUntil >= now);
            
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 @(!isActive ? "opacity-75" : "")">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center">
                        <span class="badge @(isActive ? "bg-success" : "bg-secondary")">
                            @(isActive ? "Активен" : "Неактивен")
                        </span>
                        <div class="dropdown">
                            <button class="btn btn-link text-muted p-0" data-bs-toggle="dropdown">
                                <i class="bi bi-three-dots-vertical"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    @if (test.IsLecture)
                                    {
                                        <a asp-action="EditLecture" asp-route-id="@test.Id"
                                           class="btn btn-sm btn-outline-secondary me-1">
                                            <i class="bi bi-pencil-square"></i> Редактировать
                                        </a>
                                    }
                                    else
                                    {
                                        <a asp-action="EditTest" asp-route-id="@test.Id"
                                           class="btn btn-sm btn-outline-secondary me-1">
                                            <i class="bi bi-pencil-square"></i> Редактировать
                                        </a>
                                    }
                                </li>
                                <li>
                                    <form asp-action="DuplicateTest" asp-route-id="@test.Id" method="post">
                                        <button type="submit" class="dropdown-item">
                                            <i class="bi bi-copy me-2"></i>Дублировать
                                        </button>
                                    </form>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-action="TestStatistics" asp-route-id="@test.Id">
                                        <i class="bi bi-graph-up me-2"></i>Статистика
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form asp-action="DeleteTest" asp-route-id="@test.Id" method="post"
                                          onsubmit="return confirm('Удалить тест и все результаты?')">
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="bi bi-trash me-2"></i>Удалить
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    </div>
                    <div class="card-body">
                        
                        @if (test.IsLecture)
                        {
                            <i class="bi bi-book-half text-info me-1"></i>
                            <span class="badge bg-info me-1">Лекция</span>
                        }
                        <h5 class="card-title">@test.Title</h5>

                        @if (!string.IsNullOrEmpty(test.Description))
                        {
                            <p class="text-muted small mb-3">
                                @(test.Description.Length > 80 ? test.Description.Substring(0, 80) + "..." : test.Description)
                            </p>
                        }

                        <div class="d-flex flex-wrap gap-2 mb-3">
                            <span class="badge bg-primary">
                                <i class="bi bi-question-circle me-1"></i>@test.TestElements.Count вопросов
                            </span>
                            <span class="badge bg-success">
                                <i class="bi bi-star me-1"></i>@test.MaxScore баллов
                            </span>
                            <span class="badge bg-secondary">
                                <i class="bi bi-arrow-repeat me-1"></i>@test.MaxAttempts попыток
                            </span>
                            @if (test.TimeLimitMinutes > 0)
                            {
                                <span class="badge bg-warning text-dark">
                                    <i class="bi bi-clock me-1"></i>@test.TimeLimitMinutes мин
                                </span>
                            }
                            @if (test.PassingScorePercent > 0)
                            {
                                <span class="badge bg-info">
                                    Проходной: @test.PassingScorePercent%
                                </span>
                            }
                            @if (!string.IsNullOrEmpty(test.AccessPassword))
                            {
                                <span class="badge bg-dark">
                                    <i class="bi bi-lock me-1"></i>Пароль
                                </span>
                            }
                        </div>

                        @if (test.AvailableFrom.HasValue || test.AvailableUntil.HasValue)
                        {
                            <div class="small text-muted mb-3">
                                @if (test.AvailableFrom.HasValue)
                                {
                                    <div><i class="bi bi-calendar-check me-1"></i>С: @test.AvailableFrom.Value.ToString("dd.MM.yyyy HH:mm")</div>
                                }
                                @if (test.AvailableUntil.HasValue)
                                {
                                    <div><i class="bi bi-calendar-x me-1"></i>До: @test.AvailableUntil.Value.ToString("dd.MM.yyyy HH:mm")</div>
                                }
                            </div>
                        }
                    </div>
                    <div class="card-footer bg-transparent">
                        @if (test.IsLecture)
                        {
                            <a asp-action="EditLecture"
                               asp-route-id="@test.Id"
                               class="btn btn-outline-primary w-100">
                                <i class="bi bi-pencil me-2"></i>Редактировать лекцию
                            </a>
                        }
                        else
                        {
                            <a asp-action="EditTest"
                               asp-route-id="@test.Id"
                               class="btn btn-outline-primary w-100">
                                <i class="bi bi-pencil me-2"></i>Редактировать тест
                            </a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
