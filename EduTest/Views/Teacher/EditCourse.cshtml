@model CourseViewModel
@{
    ViewData["Title"] = "–едактирование курса";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card">
            <div class="card-header text-center py-4" style="background: var(--primary-gradient);">
                <i class="bi bi-pencil-square display-4 text-white mb-2"></i>
                <h4 class="text-white mb-0">–едактирование курса</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="EditCourse" method="post">
                    <input type="hidden" asp-for="Id" />
                    
                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">
                            <i class="bi bi-fonts me-1"></i>Ќазвание курса
                        </label>
                        <input asp-for="Title" class="form-control form-control-lg" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Description" class="form-label">
                            <i class="bi bi-text-paragraph me-1"></i>ќписание
                        </label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="SelectedGroupIds" class="form-label">√руппы, которым доступен курс</label>
                        <select asp-for="SelectedGroupIds"
                                asp-items="Model.AllGroups"
                                class="form-control"
                                multiple="multiple">
                        </select>
                        <small class="text-muted">≈сли ни одна группа не выбрана Ч курс доступен всем студентам.</small>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-check-lg me-2"></i>—охранить
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-2"></i>ќтмена
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
