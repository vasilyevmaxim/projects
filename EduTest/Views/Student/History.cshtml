@model List<TestHistoryViewModel>
@{
    ViewData["Title"] = "История тестов";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">
            <i class="bi bi-clock-history me-2 text-primary"></i>История тестов
        </h2>
        <p class="text-muted mb-0">Все ваши попытки прохождения тестов</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-primary">
        <i class="bi bi-arrow-left me-2"></i>К результатам
    </a>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bi bi-inbox display-1 text-muted mb-3"></i>
            <h4>История пуста</h4>
            <p class="text-muted">Вы ещё не проходили ни одного теста</p>
            <a asp-action="Index" class="btn btn-primary">
                <i class="bi bi-play me-2"></i>Перейти к тестам
            </a>
        </div>
    </div>
}
else
{
    <div class="accordion" id="historyAccordion">
        @for (int i = 0; i < Model.Count; i++)
        {
            var test = Model[i];
            var scorePercent = test.MaxScore > 0 ? test.BestScore / test.MaxScore * 100 : 0;
            <div class="accordion-item mb-3 border-0 rounded-3 overflow-hidden shadow-sm">
                <h2 class="accordion-header">
                    <button class="accordion-button @(i > 0 ? "collapsed" : "")" type="button" 
                            data-bs-toggle="collapse" data-bs-target="#test-@test.TestId">
                        <div class="d-flex justify-content-between align-items-center w-100 me-3">
                            <div class="d-flex align-items-center">
                                <div class="me-3" style="width: 50px; height: 50px; background: var(--primary-gradient); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                                    <i class="bi bi-clipboard-check text-white fs-4"></i>
                                </div>
                                <div>
                                    <h6 class="mb-0">@test.TestTitle</h6>
                                    <small class="text-muted">@test.Attempts.Count попыток</small>
                                </div>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                <div class="progress" style="width: 100px;">
                                    <div class="progress-bar @(scorePercent >= 80 ? "bg-success" : scorePercent >= 50 ? "bg-warning" : "bg-danger")" 
                                         style="width: @scorePercent%"></div>
                                </div>
                                <span class="badge bg-primary fs-6">
                                    @Math.Round(test.BestScore, 1) / @test.MaxScore
                                </span>
                            </div>
                        </div>
                    </button>
                </h2>
                <div id="test-@test.TestId" class="accordion-collapse collapse @(i == 0 ? "show" : "")" 
                     data-bs-parent="#historyAccordion">
                    <div class="accordion-body p-0">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Попытка</th>
                                    <th class="text-center">Результат</th>
                                    <th class="text-center">Правильно</th>
                                    <th class="text-center">Время</th>
                                    <th class="text-end">Дата</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var attempt in test.Attempts)
                                {
                                    var attemptPercent = test.MaxScore > 0 ? attempt.Score / test.MaxScore * 100 : 0;
                                    <tr class="@(attempt.IsBest ? "table-success" : "")"
                                        onclick="location.href='@Url.Action("AttemptSummary", "Student", new { attemptId = attempt.AttemptId })'"
                                        style="cursor: pointer;">
                                        <td>
                                            <span class="badge bg-secondary me-2">#@attempt.AttemptNumber</span>
                                            @if (attempt.IsBest)
                                            {
                                                <span class="badge bg-success">
                                                    <i class="bi bi-star-fill me-1"></i>Лучший
                                                </span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            <div class="d-flex align-items-center justify-content-center gap-2">
                                                <div class="progress" style="width: 60px; height: 6px;">
                                                    <div class="progress-bar @(attemptPercent >= 80 ? "bg-success" : attemptPercent >= 50 ? "bg-warning" : "bg-danger")"
                                                         style="width: @attemptPercent%"></div>
                                                </div>
                                                <span class="fw-medium">@Math.Round(attempt.Score, 1)</span>
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <span class="text-success">@attempt.CorrectAnswers</span> / @attempt.TotalQuestions
                                        </td>
                                        <td class="text-center">
                                            <i class="bi bi-clock text-muted me-1"></i>
                                            @attempt.TimeSpentFormatted
                                        </td>
                                        <td class="text-end text-muted">
                                            @attempt.CompletedAt.ToString("dd.MM.yyyy HH:mm")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>
}
