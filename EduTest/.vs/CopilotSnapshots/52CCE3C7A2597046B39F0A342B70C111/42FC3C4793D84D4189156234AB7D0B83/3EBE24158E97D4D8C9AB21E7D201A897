@model TakeTestViewModel
@{
    ViewData["Title"] = $"Тест: {Model.TestTitle}";
}

<div class="card mb-4 sticky-top" style="top: 1rem; z-index: 100;">
    <div class="card-body py-3">
        <div class="row align-items-center">
            <div class="col-md-4">
                <h5 class="mb-0">
                    <i class="bi bi-clipboard-check me-2 text-primary"></i>@Model.TestTitle
                </h5>
                <small class="text-muted">@Model.CourseName</small>
            </div>
            <div class="col-md-4 text-center">
                @if (Model.TimeLimitMinutes > 0)
                {
                    <div class="timer-display" id="timer">
                        <i class="bi bi-clock"></i>
                        <span id="timerText">@Model.TimeLimitMinutes:00</span>
                    </div>
                }
                else
                {
                    <span class="badge bg-secondary">
                        <i class="bi bi-infinity me-1"></i>Без ограничения времени
                    </span>
                }
            </div>
            <div class="col-md-4 text-end">
                <span class="badge bg-primary me-2">
                    <i class="bi bi-star me-1"></i>Макс. @Model.MaxScore баллов
                </span>
                <span class="badge bg-warning text-dark">
                    <i class="bi bi-arrow-repeat me-1"></i>@Model.AttemptsLeft попыток
                </span>
            </div>
        </div>
        
        <div class="progress mt-3" style="height: 6px;">
            <div class="progress-bar" id="progressBar" style="width: 0%"></div>
        </div>
        <small class="text-muted">
            <span id="answeredCount">0</span> из @Model.Questions.Count вопросов отвечено
        </small>
    </div>
</div>

<form asp-action="SubmitTest" method="post" id="testForm">
    <input type="hidden" name="testId" value="@Model.TestId" />
    <input type="hidden" name="timeSpentSeconds" id="timeSpentSeconds" value="0" />
    <input type="hidden" name="tabSwitchCount" id="tabSwitchCount" value="0" />

    @for (int i = 0; i < Model.Questions.Count; i++)
    {
        var question = Model.Questions[i];
        <div class="question-card" id="question-@question.ElementId" data-index="@i">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div class="d-flex align-items-center">
                    <span class="badge bg-primary me-2 fs-6">@question.Order</span>
                    <span class="test-type-badge @GetTypeBadgeClass(question.Type)">
                        <i class="@GetTypeIcon(question.Type) me-1"></i>
                        @GetTypeName(question.Type)
                    </span>
                </div>
                @if (question.TimeLimit > 0)
                {
                    <span class="badge bg-warning text-dark">
                        <i class="bi bi-stopwatch me-1"></i>@question.TimeLimit сек
                    </span>
                }
            </div>

            @if (!string.IsNullOrEmpty(question.ImageUrl))
            {
                <div class="mb-3">
                    <img src="@question.ImageUrl" alt="Изображение к вопросу" class="img-fluid rounded" style="max-height: 300px;">
                </div>
            }

            <p class="fs-5 mb-4">@question.QuestionText</p>

            @if (!string.IsNullOrEmpty(question.Hint))
            {
                <div class="alert alert-light mb-3">
                    <i class="bi bi-lightbulb me-2 text-warning"></i>
                    <em>Подсказка: @question.Hint</em>
                </div>
            }

            <div class="answer-area">
                @switch (question.Type)
                {
                    case ElementType.TextInput:
                        <input type="text" name="answers[answer_@question.ElementId]" 
                               class="form-control form-control-lg answer-input" 
                               placeholder="Введите ваш ответ" />
                        break;

                    case ElementType.Dropdown:
                        <select name="answers[answer_@question.ElementId]" class="form-select form-select-lg answer-input">
                            <option value="">— Выберите ответ —</option>
                            @foreach (var option in question.Options)
                            {
                                <option value="@option">@option</option>
                            }
                        </select>
                        break;

                    case ElementType.RadioButton:
                        <div class="list-group">
                            @foreach (var option in question.Options)
                            {
                                <label class="list-group-item list-group-item-action d-flex align-items-center gap-3">
                                    <input type="radio" name="answers[answer_@question.ElementId]" 
                                           value="@option" class="form-check-input answer-input" />
                                    <span>@option</span>
                                </label>
                            }
                        </div>
                        break;

                    case ElementType.Checkbox:
                        <div class="list-group">
                            @foreach (var option in question.Options)
                            {
                                <label class="list-group-item list-group-item-action d-flex align-items-center gap-3">
                                    <input type="checkbox" name="answers[multi_@(question.ElementId)_@option]" 
                                           value="@option" class="form-check-input answer-input" />
                                    <span>@option</span>
                                </label>
                            }
                        </div>
                        <small class="text-muted mt-2 d-block">
                            <i class="bi bi-info-circle me-1"></i>Можно выбрать несколько вариантов
                        </small>
                        break;

                    case ElementType.TrueFalse:
                        <div class="row g-3">
                            <div class="col-6">
                                <label class="card h-100 text-center p-4" style="cursor: pointer;">
                                    <input type="radio" name="answers[answer_@question.ElementId]" 
                                           value="Да" class="d-none answer-input" />
                                    <i class="bi bi-check-circle display-4 text-success mb-2"></i>
                                    <span class="fs-5 fw-medium">Да</span>
                                </label>
                            </div>
                            <div class="col-6">
                                <label class="card h-100 text-center p-4" style="cursor: pointer;">
                                    <input type="radio" name="answers[answer_@question.ElementId]" 
                                           value="Нет" class="d-none answer-input" />
                                    <i class="bi bi-x-circle display-4 text-danger mb-2"></i>
                                    <span class="fs-5 fw-medium">Нет</span>
                                </label>
                            </div>
                        </div>
                        break;

                    case ElementType.NumericRange:
                        <div class="input-group input-group-lg">
                            <span class="input-group-text"><i class="bi bi-123"></i></span>
                            <input type="number" step="any" name="answers[answer_@question.ElementId]" 
                                   class="form-control answer-input" placeholder="Введите число" />
                        </div>
                        break;

                    case ElementType.Matching:
                        <div class="alert alert-info mb-3">
                            <i class="bi bi-info-circle me-2"></i>
                            Сопоставьте элементы из левой колонки с правой. 
                            Формат ответа: A-1, B-2, C-3
                        </div>
                        <div class="row">
                            <div class="col-md-5">
                                <div class="list-group">
                                    @for (int j = 0; j < question.LeftItems.Count; j++)
                                    {
                                        <div class="list-group-item">
                                            <span class="badge bg-primary me-2">@((char)('A' + j))</span>
                                            @question.LeftItems[j]
                                        </div>
                                    }
                                </div>
                            </div>
                            <div class="col-md-2 text-center d-flex align-items-center justify-content-center">
                                <i class="bi bi-arrows display-4 text-muted"></i>
                            </div>
                            <div class="col-md-5">
                                <div class="list-group">
                                    @for (int j = 0; j < question.RightItems.Count; j++)
                                    {
                                        <div class="list-group-item">
                                            <span class="badge bg-secondary me-2">@(j + 1)</span>
                                            @question.RightItems[j]
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                        <input type="text" name="answers[answer_@question.ElementId]" 
                               class="form-control mt-3 answer-input" 
                               placeholder="Пример: A-1|B-2|C-3" />
                        break;

                    case ElementType.Ordering:
                        <div class="alert alert-info mb-3">
                            <i class="bi bi-info-circle me-2"></i>
                            Расставьте элементы в правильном порядке. 
                            Введите номера через запятую.
                        </div>
                        <div class="list-group mb-3">
                            @for (int j = 0; j < question.ItemsToOrder.Count; j++)
                            {
                                <div class="list-group-item d-flex align-items-center">
                                    <span class="badge bg-secondary me-3">@(j + 1)</span>
                                    @question.ItemsToOrder[j]
                                </div>
                            }
                        </div>
                        <input type="text" name="answers[answer_@question.ElementId]" 
                               class="form-control answer-input" 
                               placeholder="Пример: 2,1,4,3" />
                        break;

                    case ElementType.FillBlanks:
                        <div class="alert alert-info mb-3">
                            <i class="bi bi-info-circle me-2"></i>
                            Заполните пропуски. Разделяйте ответы символом |
                        </div>
                        <input type="text" name="answers[answer_@question.ElementId]" 
                               class="form-control form-control-lg answer-input" 
                               placeholder="Ответ1|Ответ2|Ответ3" />
                        break;
                }
            </div>
        </div>
    }

    <div class="card bg-light mt-4">
        <div class="card-body text-center py-4">
            <p class="text-muted mb-3">
                <i class="bi bi-exclamation-triangle me-2"></i>
                После нажатия кнопки "Завершить тест" ответы изменить будет нельзя.
            </p>
            <div class="d-flex justify-content-center gap-3">
                <button type="button" class="btn btn-success btn-lg px-5" data-bs-toggle="modal" data-bs-target="#confirmModal">
                    <i class="bi bi-check-lg me-2"></i>Завершить тест
                </button>
            </div>
        </div>
    </div>

    <div class="modal fade" id="confirmModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Подтверждение</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="text-center mb-4">
                        <i class="bi bi-question-circle display-1 text-warning"></i>
                    </div>
                    <p class="text-center fs-5">Вы уверены, что хотите завершить тест?</p>
                    <p class="text-center text-muted">
                        Отвечено <strong id="modalAnsweredCount">0</strong> из @Model.Questions.Count вопросов
                    </p>
                </div>
                <div class="modal-footer justify-content-center">
                    <button type="button" class="btn btn-secondary btn-lg" data-bs-dismiss="modal">
                        Вернуться к тесту
                    </button>
                    <button type="submit" class="btn btn-success btn-lg">
                        <i class="bi bi-check-lg me-2"></i>Да, завершить
                    </button>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        // Таймер
        @if (Model.TimeLimitMinutes > 0)
        {
            <text>
            let timeLeft = @(Model.TimeLimitMinutes * 60);
            const timerElement = document.getElementById('timer');
            const timerText = document.getElementById('timerText');
            
            const timerInterval = setInterval(() => {
                timeLeft--;
                const minutes = Math.floor(timeLeft / 60);
                const seconds = timeLeft % 60;
                timerText.textContent = `${minutes}:${seconds.toString().padStart(2, '0')}`;
                
                document.getElementById('timeSpentSeconds').value = @(Model.TimeLimitMinutes * 60) - timeLeft;
                
                if (timeLeft <= 60) {
                    timerElement.classList.add('warning');
                }
                
                if (timeLeft <= 0) {
                    clearInterval(timerInterval);
                    document.getElementById('testForm').submit();
                }
            }, 1000);
            </text>
        }
        else
        {
            <text>
            let startTime = new Date();
            setInterval(() => {
                const elapsed = Math.floor((new Date() - startTime) / 1000);
                document.getElementById('timeSpentSeconds').value = elapsed;
            }, 1000);
            </text>
        }

        // Подсчёт отвеченных вопросов
        function updateProgress() {
            const inputs = document.querySelectorAll('.answer-input');
            let answered = 0;
            const questionIds = new Set();
            
            inputs.forEach(input => {
                const questionCard = input.closest('.question-card');
                const questionId = questionCard.id;
                
                if (input.type === 'checkbox' || input.type === 'radio') {
                    if (input.checked) questionIds.add(questionId);
                } else if (input.value.trim()) {
                    questionIds.add(questionId);
                }
            });
            
            answered = questionIds.size;
            document.getElementById('answeredCount').textContent = answered;
            document.getElementById('modalAnsweredCount').textContent = answered;
            
            const progress = (answered / @Model.Questions.Count) * 100;
            document.getElementById('progressBar').style.width = progress + '%';
        }

        document.querySelectorAll('.answer-input').forEach(input => {
            input.addEventListener('change', updateProgress);
            input.addEventListener('input', updateProgress);
        });

        // True/False стилизация
        document.querySelectorAll('input[type="radio"]').forEach(radio => {
            radio.addEventListener('change', function() {
                const card = this.closest('.card');
                if (card) {
                    document.querySelectorAll(`input[name="${this.name}"]`).forEach(r => {
                        r.closest('.card')?.classList.remove('border-primary', 'bg-light');
                    });
                    if (this.checked) {
                        card.classList.add('border-primary', 'bg-light');
                    }
                }
            });
        });

        // Отслеживание переключения вкладок
        @if (Model.DetectTabSwitch)
        {
            <text>
            let tabSwitchCount = 0;
            document.addEventListener('visibilitychange', () => {
                if (document.hidden) {
                    tabSwitchCount++;
                    document.getElementById('tabSwitchCount').value = tabSwitchCount;
                    alert('Внимание! Переключение вкладки зафиксировано.');
                }
            });
            </text>
        }
    </script>
}

@functions {
    string GetTypeBadgeClass(ElementType type) => type switch
    {
        ElementType.TextInput => "bg-primary text-white",
        ElementType.Dropdown => "bg-info text-white",
        ElementType.RadioButton => "bg-info text-white",
        ElementType.Checkbox => "bg-success text-white",
        ElementType.TrueFalse => "bg-warning text-dark",
        ElementType.Matching => "bg-danger text-white",
        ElementType.Ordering => "bg-secondary text-white",
        ElementType.FillBlanks => "text-white",
        ElementType.NumericRange => "text-white",
        _ => "bg-secondary text-white"
    };

    string GetTypeIcon(ElementType type) => type switch
    {
        ElementType.TextInput => "bi bi-input-cursor-text",
        ElementType.Dropdown => "bi bi-menu-down",
        ElementType.RadioButton => "bi bi-ui-radios",
        ElementType.Checkbox => "bi bi-ui-checks",
        ElementType.TrueFalse => "bi bi-toggle-on",
        ElementType.Matching => "bi bi-arrows",
        ElementType.Ordering => "bi bi-sort-numeric-down",
        ElementType.FillBlanks => "bi bi-paragraph",
        ElementType.NumericRange => "bi bi-123",
        _ => "bi bi-question"
    };

    string GetTypeName(ElementType type) => type switch
    {
        ElementType.TextInput => "Текстовый ввод",
        ElementType.Dropdown => "Выбор из списка",
        ElementType.RadioButton => "Одиночный выбор",
        ElementType.Checkbox => "Множественный выбор",
        ElementType.TrueFalse => "Да/Нет",
        ElementType.Matching => "Сопоставление",
        ElementType.Ordering => "Упорядочивание",
        ElementType.FillBlanks => "Пропуски",
        ElementType.NumericRange => "Числовой ответ",
        _ => "Вопрос"
    };
}
