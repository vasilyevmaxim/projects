@model List<CourseViewModel>
@{
    ViewData["Title"] = "Управление курсами";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-journal-text me-2"></i>Курсы</h2>
    <a asp-action="CreateCourse" class="btn btn-success">
        <i class="bi bi-plus-lg me-2"></i>Создать курс
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>
        Курсы пока не созданы. Нажмите "Создать курс" для начала работы.
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var course in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 test-card">
                    <div class="card-header bg-light">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-book me-2 text-primary"></i>@course.Title
                        </h5>
                    </div>
                    <div class="card-body">
                        <p class="card-text text-muted">
                            @(course.Description ?? "Описание отсутствует")
                        </p>
                        <div class="d-flex justify-content-between text-muted small">
                            <span><i class="bi bi-file-text me-1"></i>@course.TestsCount тестов</span>
                            <span><i class="bi bi-star me-1"></i>@course.TotalMaxScore баллов</span>
                        </div>
                    </div>
                    <div class="card-footer bg-white">
                        <div class="btn-group w-100" role="group">
                            <a asp-action="CourseTests" asp-route-id="@course.Id" class="btn btn-outline-primary">
                                <i class="bi bi-list-ul me-1"></i>Тесты
                            </a>
                            <a asp-action="EditCourse" asp-route-id="@course.Id" class="btn btn-outline-secondary">
                                <i class="bi bi-pencil me-1"></i>Изменить
                            </a>
                            <form asp-action="DeleteCourse" asp-route-id="@course.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Удалить курс и все его тесты?');">
                                <button type="submit" class="btn btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
