@model List<PasswordResetRequest>
@{
    ViewData["Title"] = "Заявки на сброс пароля";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">
            <i class="bi bi-key me-2 text-primary"></i>Заявки на сброс пароля
        </h2>
        <p class="text-muted mb-0">Управление заблокированными аккаунтами</p>
    </div>
    <span class="badge bg-primary fs-5">@Model.Count заявок</span>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bi bi-inbox display-1 text-muted mb-3"></i>
            <h4>Заявок нет</h4>
            <p class="text-muted">Все аккаунты в порядке</p>
        </div>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var request in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-header bg-warning bg-opacity-10 d-flex justify-content-between align-items-center">
                        <span class="badge bg-warning text-dark">
                            <i class="bi bi-clock me-1"></i>Ожидает
                        </span>
                        <small class="text-muted">@request.RequestedAt.ToString("dd.MM.yyyy HH:mm")</small>
                    </div>
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <div class="avatar me-3">
                                @(request.User?.FullName.Substring(0, 1).ToUpper())
                            </div>
                            <div>
                                <h6 class="mb-0">@request.User?.FullName</h6>
                                <small class="text-muted">@request.User?.Email</small>
                            </div>
                        </div>

                        <div class="mb-3">
                            <span class="badge bg-secondary">
                                <i class="bi bi-people me-1"></i>Группа: @request.User?.GroupNumber
                            </span>
                        </div>

                        <form asp-action="ApprovePasswordReset" asp-route-id="@request.Id" method="post">
                            <div class="mb-3">
                                <label class="form-label">Новый пароль</label>
                                <input type="text" name="newPassword" class="form-control" 
                                       required minlength="6" value="@($"pass{new Random().Next(1000, 9999)}")" />
                            </div>
                            
                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-success">
                                    <i class="bi bi-check-lg me-2"></i>Сбросить пароль
                                </button>
                            </div>
                        </form>
                        
                        <form asp-action="RejectPasswordReset" asp-route-id="@request.Id" method="post" class="mt-2">
                            <button type="submit" class="btn btn-outline-danger w-100">
                                <i class="bi bi-x-lg me-2"></i>Отклонить (разблокировать)
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
