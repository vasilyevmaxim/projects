@model List<PasswordResetRequest>
@{
    ViewData["Title"] = "Заявки на сброс пароля";
}

<h2 class="mb-4"><i class="bi bi-key me-2"></i>Заявки на сброс пароля</h2>

@if (!Model.Any())
{
    <div class="alert alert-success">
        <i class="bi bi-check-circle me-2"></i>
        Нет необработанных заявок.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover">
            <thead class="table-light">
                <tr>
                    <th>Студент</th>
                    <th>Группа</th>
                    <th>Email</th>
                    <th>Дата заявки</th>
                    <th class="text-end">Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var request in Model)
                {
                    <tr>
                        <td>
                            <i class="bi bi-person me-2"></i>@request.User?.FullName
                        </td>
                        <td>
                            <span class="badge bg-secondary">@request.User?.GroupNumber</span>
                        </td>
                        <td>@request.User?.Email</td>
                        <td class="text-muted">@request.RequestedAt.ToString("dd.MM.yyyy HH:mm")</td>
                        <td class="text-end">
                            <button type="button" class="btn btn-sm btn-success" 
                                    data-bs-toggle="modal" 
                                    data-bs-target="#resetModal@(request.Id)">
                                <i class="bi bi-check-lg me-1"></i>Сбросить пароль
                            </button>
                            <form asp-action="RejectPasswordReset" asp-route-id="@request.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Отклонить заявку?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-x-lg me-1"></i>Отклонить
                                </button>
                            </form>
                        </td>
                    </tr>

                    <div class="modal fade" id="resetModal@(request.Id)" tabindex="-1">
                        <div class="modal-dialog">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title">Сброс пароля для @request.User?.FullName</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <form asp-action="ApprovePasswordReset" asp-route-id="@request.Id" method="post">
                                    <div class="modal-body">
                                        <div class="mb-3">
                                            <label class="form-label">Новый пароль</label>
                                            <input type="text" name="newPassword" class="form-control" 
                                                   value="@($"student{Random.Shared.Next(1000, 9999)}")" required />
                                            <div class="form-text">Сообщите этот пароль студенту</div>
                                        </div>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                                        <button type="submit" class="btn btn-success">
                                            <i class="bi bi-check-lg me-1"></i>Сбросить пароль
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </tbody>
        </table>
    </div>
}
