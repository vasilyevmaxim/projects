/* Custom styles for Student Testing System */

:root {
    --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    --success-gradient: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
    --danger-gradient: linear-gradient(135deg, #eb3349 0%, #f45c43 100%);
    --warning-gradient: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    --info-gradient: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
    --dark-gradient: linear-gradient(135deg, #232526 0%, #414345 100%);
    --card-shadow: 0 10px 40px rgba(0,0,0,0.1);
    --card-hover-shadow: 0 20px 60px rgba(0,0,0,0.15);
}

* {
    font-family: 'Inter', sans-serif;
}

body {
    background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
    min-height: 100vh;
}

.navbar {
    background: var(--primary-gradient) !important;
    box-shadow: 0 4px 20px rgba(102, 126, 234, 0.4);
    padding: 1rem 0;
}

.navbar-brand {
    font-weight: 700;
    font-size: 1.5rem;
    letter-spacing: -0.5px;
}

.navbar-brand i {
    background: rgba(255,255,255,0.2);
    padding: 8px;
    border-radius: 10px;
    margin-right: 10px;
}

.nav-link {
    font-weight: 500;
    padding: 0.5rem 1rem !important;
    border-radius: 8px;
    transition: all 0.3s ease;
    margin: 0 4px;
}

.nav-link:hover {
    background: rgba(255,255,255,0.15);
}

.card {
    border: none;
    border-radius: 16px;
    box-shadow: var(--card-shadow);
    transition: all 0.3s ease;
    /* overflow: hidden; - REMOVED to allow dropdowns to overflow */
}

.card:hover {
    transform: translateY(-5px);
    box-shadow: var(--card-hover-shadow);
}

.card-header {
    border-bottom: none;
    padding: 1.25rem 1.5rem;
    font-weight: 600;
}

.card-header:first-child {
    border-radius: 16px 16px 0 0;
}

.card-footer:last-child {
    border-radius: 0 0 16px 16px;
}

.card-body {
    padding: 1.5rem;
}

.btn {
    border-radius: 10px;
    font-weight: 500;
    padding: 0.6rem 1.25rem;
    transition: all 0.3s ease;
    border: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
}

.btn-primary {
    background-color: #667eea;
    box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
    border: none;
    color: white;
}

.btn-primary:hover {
    background-color: #5a6fd6;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(102, 126, 234, 0.5);
}

.btn-success {
    background-color: #11998e;
    box-shadow: 0 4px 15px rgba(17, 153, 142, 0.4);
    border: none;
    color: white;
}

.btn-success:hover {
    background-color: #0e8c82;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(17, 153, 142, 0.5);
}

.btn-danger {
    background-color: #eb3349;
    box-shadow: 0 4px 15px rgba(235, 51, 73, 0.4);
    border: none;
    color: white;
}

.btn-danger:hover {
    background-color: #d42035;
}

.btn-warning {
    background-color: #f093fb;
    box-shadow: 0 4px 15px rgba(240, 147, 251, 0.4);
    border: none;
    color: white;
}

.btn-warning:hover {
    background-color: #d670e0;
    color: white;
}

.btn-info {
    background-color: #4facfe;
    box-shadow: 0 4px 15px rgba(79, 172, 254, 0.4);
    border: none;
    color: white;
}

.btn-info:hover {
    background-color: #3a95e4;
    color: white;
}

.btn-outline-primary {
    border: 2px solid #667eea;
    color: #667eea;
}

.btn-outline-primary:hover {
    background-color: #667eea;
    border-color: transparent !important;
    color: white;
}

.form-control, .form-select {
    border-radius: 10px;
    border: 2px solid #e9ecef;
    padding: 0.75rem 1rem;
    transition: all 0.3s ease;
}

.form-control:focus, .form-select:focus {
    border-color: #667eea;
    box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.15);
}

.badge {
    padding: 0.5em 1em;
    border-radius: 8px;
    font-weight: 500;
}

.progress {
    border-radius: 10px;
    height: 10px;
    background: #e9ecef;
    overflow: hidden;
}

.progress-bar {
    border-radius: 10px;
}

.alert {
    border: none;
    border-radius: 12px;
    padding: 1rem 1.25rem;
}

.alert-success {
    background: linear-gradient(135deg, rgba(17, 153, 142, 0.1) 0%, rgba(56, 239, 125, 0.1) 100%);
    color: #0d6c5f;
}

.alert-danger {
    background: linear-gradient(135deg, rgba(235, 51, 73, 0.1) 0%, rgba(244, 92, 67, 0.1) 100%);
    color: #c23a4a;
}

.alert-info {
    background: linear-gradient(135deg, rgba(79, 172, 254, 0.1) 0%, rgba(0, 242, 254, 0.1) 100%);
    color: #2980b9;
}

.table {
    border-radius: 12px;
    overflow: hidden;
}

.table thead th {
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    border: none;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.5px;
    color: #6c757d;
    padding: 1rem;
}

.table tbody td {
    padding: 1rem;
    vertical-align: middle;
    border-color: #f1f3f4;
}

.accordion-button {
    border-radius: 12px !important;
    font-weight: 600;
}

.accordion-button:not(.collapsed) {
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
    color: #667eea;
}

.stat-card {
    background: white;
    border-radius: 16px;
    padding: 1.5rem;
    text-align: center;
    box-shadow: var(--card-shadow);
}

.stat-card .icon {
    width: 60px;
    height: 60px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1rem;
    font-size: 1.5rem;
    color: white;
}

.stat-card .value {
    font-size: 2rem;
    font-weight: 700;
    color: #2d3436;
}

.stat-card .label {
    color: #6c757d;
    font-size: 0.875rem;
    margin-top: 0.25rem;
}

.question-card {
    background: white;
    border-radius: 16px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    box-shadow: var(--card-shadow);
    border-left: 4px solid #667eea;
}

.question-card.correct {
    border-left-color: #11998e;
    background: linear-gradient(135deg, rgba(17, 153, 142, 0.05) 0%, rgba(56, 239, 125, 0.05) 100%);
}

.question-card.wrong {
    border-left-color: #eb3349;
    background: linear-gradient(135deg, rgba(235, 51, 73, 0.05) 0%, rgba(244, 92, 67, 0.05) 100%);
}

.question-card.partial {
    border-left-color: #f5a623;
    background: linear-gradient(135deg, rgba(245, 166, 35, 0.05) 0%, rgba(245, 166, 35, 0.05) 100%);
}

.timer-display {
    background: var(--dark-gradient);
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: 12px;
    font-size: 1.25rem;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
}

.timer-display.warning {
    background: var(--warning-gradient);
    animation: pulse 1s infinite;
}

@keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.7; }
}

.course-card {
    position: relative;
    overflow: hidden;
}

.course-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: var(--primary-gradient);
    border-radius: 16px 16px 0 0;
}

.test-type-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.35rem 0.75rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 500;
}

.avatar {
    width: 40px;
    height: 40px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    color: white;
    background: var(--primary-gradient);
}

.dropdown-menu {
    position: absolute;
    z-index: 1050;
    border: none;
    border-radius: 12px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.15);
    padding: 0.5rem;
}

.dropdown-item {
    border-radius: 8px;
    padding: 0.6rem 1rem;
    font-weight: 500;
}

.dropdown-item:hover {
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
}

footer {
    background: white;
    box-shadow: 0 -4px 20px rgba(0,0,0,0.05);
}

.hero-section {
    background: var(--primary-gradient);
    border-radius: 24px;
    padding: 3rem;
    color: white;
    position: relative;
    overflow: hidden;
}

.hero-section::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 60%;
    height: 200%;
    background: rgba(255,255,255,0.1);
    transform: rotate(25deg);
}

.form-check-input {
    width: 1.25rem;
    height: 1.25rem;
    border: 2px solid #dee2e6;
    border-radius: 6px;
}

.form-check-input:checked {
    background: var(--primary-gradient);
    border-color: transparent;
}

.form-check-input[type=radio] {
    border-radius: 50%;
}

.list-group-item {
    border: none;
    border-radius: 12px !important;
    margin-bottom: 0.5rem;
    padding: 1rem 1.25rem;
    transition: all 0.3s ease;
}

.list-group-item:hover {
    background: #f8f9fa;
    transform: translateX(5px);
}

.modal-content {
    border: none;
    border-radius: 20px;
    overflow: hidden;
}

.modal-header {
    background: var(--primary-gradient);
    color: white;
    border: none;
}

.tooltip-inner {
    border-radius: 8px;
    padding: 0.5rem 1rem;
}

.skeleton {
    background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
    background-size: 200% 100%;
    animation: skeleton-loading 1.5s infinite;
}

@keyframes skeleton-loading {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
}

.floating-action-btn {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    box-shadow: 0 8px 25px rgba(102, 126, 234, 0.4);
    z-index: 1000;
}

.score-circle {
    width: 150px;
    height: 150px;
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin: 0 auto;
    position: relative;
}

.score-circle::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    padding: 8px;
    background: var(--primary-gradient);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
}

.score-circle .score {
    font-size: 2.5rem;
    font-weight: 700;
    color: #667eea;
}

.score-circle .label {
    font-size: 0.875rem;
    color: #6c757d;
}

.glow-success {
    box-shadow: 0 0 30px rgba(17, 153, 142, 0.3);
}

.glow-danger {
    box-shadow: 0 0 30px rgba(235, 51, 73, 0.3);
}

/* ===== FILL BLANKS DRAG & DROP ===== */
.word-bank {
    border: 2px dashed #dee2e6;
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
}

.word-item {
    transition: all 0.2s ease;
    user-select: none;
}

.word-item:hover:not(.used) {
    transform: translateY(-2px);
    box-shadow: 0 4px 8px rgba(0,0,0,0.15);
}

.word-item.used {
    opacity: 0.5;
    text-decoration: line-through;
}

.blank-slot {
    transition: all 0.2s ease;
    min-height: 32px;
    vertical-align: middle;
}

.blank-slot:hover {
    background-color: #e3f2fd !important;
    border-color: #2196f3 !important;
}

.blank-slot.drag-over {
    background-color: #bbdefb !important;
    transform: scale(1.05);
}

.fill-blanks-text {
    font-size: 1.1rem;
    line-height: 2.2;
}

.blank-value {
    font-weight: 600;
    color: #198754;
}

/* ===== FIX DROPDOWN IN TABLES ===== */
.card:has(.dropdown) {
    overflow: visible !important;
}

.card-body:has(.dropdown) {
    overflow: visible !important;
}

.table-responsive:has(.dropdown) {
    overflow: visible !important;
}

.dropdown-menu {
    position: absolute;
    z-index: 1050;
}

/* Для таблиц со статистикой */
.table-responsive {
    overflow-x: auto;
    overflow-y: visible;
}

/* Аннулированные попытки */
.voided-attempt {
    opacity: 0.7;
    background-color: #f8f9fa;
}

.voided-badge {
    font-size: 0.7rem;
}
