@model ForgotPasswordViewModel
@{
    ViewData["Title"] = "Восстановление пароля";
    Layout = "_Layout";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5 col-lg-4">
        <div class="card">
            <div class="card-header text-center py-4" style="background: var(--warning-gradient);">
                <i class="bi bi-key display-4 text-white mb-2"></i>
                <h4 class="text-white mb-0">Восстановление пароля</h4>
            </div>
            <div class="card-body p-4">
                @if (ViewBag.Success != null)
                {
                    <div class="alert alert-success">
                        <i class="bi bi-check-circle me-2"></i>@ViewBag.Success
                    </div>
                    
                    <div class="text-center">
                        <a asp-action="Login" class="btn btn-primary">
                            <i class="bi bi-arrow-left me-2"></i>Вернуться ко входу
                        </a>
                    </div>
                }
                else
                {
                    @if (!string.IsNullOrEmpty(ViewBag.Error))
                    {
                        <div class="alert alert-danger">
                            <i class="bi bi-exclamation-triangle me-2"></i>@ViewBag.Error
                        </div>
                    }

                    <div class="alert alert-info mb-4">
                        <i class="bi bi-info-circle me-2"></i>
                        После отправки заявки преподаватель назначит вам новый пароль.
                    </div>

                    <form asp-action="ForgotPassword" method="post">
                        <div class="mb-4">
                            <label asp-for="Email" class="form-label">
                                <i class="bi bi-envelope me-1"></i>Ваш Email
                            </label>
                            <input asp-for="Email" class="form-control form-control-lg" 
                                   placeholder="student@example.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-warning btn-lg">
                                <i class="bi bi-send me-2"></i>Отправить заявку
                            </button>
                            <a asp-action="Login" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-2"></i>Назад
                            </a>
                        </div>
                    </form>
                }
            </div>
        </div>
    </div>
</div>
